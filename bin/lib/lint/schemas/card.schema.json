{
	"$id": "https://gxp.dev/schemas/card.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "GxP Form Card",
	"description": "A card inside additionalTabs.cards or a nested card_list/tabs_list.",
	"type": "object",
	"required": ["type"],
	"properties": {
		"type": {
			"type": "string",
			"enum": [
				"fields_list",
				"data_table",
				"card_list",
				"tabs_list",
				"info_card",
				"render_list",
				"carousel",
				"grid_view",
				"component",
				"data_display",
				"button_group",
				"form_builder"
			]
		},
		"title": { "type": ["string", "null"] },
		"subtitle": { "type": ["string", "null"] },
		"tabId": { "type": ["string", "null"] },
		"icon": { "type": ["string", "null"] },
		"cols": { "$ref": "common.schema.json#/$defs/gridCols" },
		"colsSm": { "$ref": "common.schema.json#/$defs/gridCols" },
		"colsMd": { "$ref": "common.schema.json#/$defs/gridCols" },
		"colsLg": { "$ref": "common.schema.json#/$defs/gridCols" },
		"colsXl": { "$ref": "common.schema.json#/$defs/gridCols" },
		"marginBottom": { "type": "integer", "minimum": 0 },
		"showCard": { "type": "boolean" },
		"border": { "type": "boolean" },
		"classList": {
			"type": "array",
			"items": { "type": "string" }
		},
		"bodyClassList": {
			"type": "array",
			"items": { "type": "string" }
		},
		"cardWrapperClassList": {
			"type": "array",
			"items": { "type": "string" }
		},
		"wrapperClassList": {
			"type": "array",
			"items": { "type": "string" }
		},
		"fieldsListClassList": {
			"type": "array",
			"items": { "type": "string" }
		},
		"spacerY": { "type": ["string", "number", "null"] },
		"spacerX": { "type": ["string", "number", "null"] },
		"gutterY": { "type": ["string", "number", "null"] },
		"gutterX": { "type": ["string", "number", "null"] },
		"collapse": {
			"type": "object",
			"properties": {
				"heading": { "type": "string" },
				"label": { "type": "string" },
				"smooth": { "type": "boolean" },
				"showingByDefault": { "type": "boolean" }
			},
			"additionalProperties": true
		},
		"permissions": {
			"type": "array",
			"items": { "type": "string" }
		},
		"features": {
			"type": "array",
			"items": { "type": "string" }
		},
		"footerButton": {
			"type": "object",
			"properties": {
				"text": { "type": "string" },
				"route": { "type": "string" },
				"icon": { "type": ["string", "null"] },
				"classList": {
					"type": "array",
					"items": { "type": "string" }
				}
			},
			"additionalProperties": true
		},
		"listKey": { "type": ["string", "null"] },
		"listData": { "type": "array" },
		"condition": { "type": ["string", "null"] },
		"conditionParams": {
			"$ref": "common.schema.json#/$defs/conditionParams"
		},
		"fieldsList": {
			"type": "array",
			"items": { "$ref": "field.schema.json" }
		},
		"cards": {
			"type": "array",
			"items": { "$ref": "card.schema.json" }
		},
		"tabsList": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["title"],
				"properties": {
					"title": { "type": "string" },
					"tabId": { "type": ["string", "null"] },
					"icon": { "type": ["string", "null"] },
					"cards": {
						"type": "array",
						"items": { "$ref": "card.schema.json" }
					}
				},
				"additionalProperties": true
			}
		},
		"buttons": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["text"],
				"properties": {
					"text": { "type": "string" },
					"type": { "type": "string" },
					"color": { "type": ["string", "null"] },
					"icon": { "type": ["string", "null"] },
					"href": { "type": ["string", "null"] },
					"route": { "type": ["string", "null"] },
					"method": { "type": ["string", "null"] },
					"data": { "type": "object" },
					"eventName": { "type": ["string", "null"] },
					"action": { "type": ["string", "null"] },
					"classList": {
						"type": "array",
						"items": { "type": "string" }
					},
					"permissions": {
						"type": "array",
						"items": { "type": "string" }
					},
					"features": {
						"type": "array",
						"items": { "type": "string" }
					},
					"condition": { "type": ["string", "null"] },
					"conditionParams": {
						"$ref": "common.schema.json#/$defs/conditionParams"
					}
				},
				"additionalProperties": true
			}
		},
		"grouped": { "type": "boolean" },
		"draggable": { "type": "boolean" },
		"dragTargetData": { "type": ["string", "null"] },
		"createConfig": { "type": "object" },
		"updateConfig": { "type": "object" },
		"delete": { "type": "object" },
		"component": { "type": ["string", "null"] },
		"componentProps": { "type": "object" },
		"props": { "type": "object" },
		"headers": {
			"type": "array",
			"items": { "type": ["string", "object"] }
		},
		"rows": { "type": "array" },
		"options": { "type": "object" },
		"tableTitle": { "type": ["string", "null"] },
		"itemList": { "type": "array" },
		"tileList": { "type": "array" },
		"gridData": { "type": "object" },
		"loopKey": { "type": ["string", "null"] },
		"loopList": { "type": "array" }
	},
	"allOf": [
		{
			"if": {
				"properties": { "type": { "const": "fields_list" } },
				"required": ["type"]
			},
			"then": {
				"required": ["fieldsList"],
				"properties": {
					"fieldsList": {
						"type": "array",
						"items": { "$ref": "field.schema.json" }
					}
				}
			}
		},
		{
			"if": {
				"properties": { "type": { "const": "card_list" } },
				"required": ["type"]
			},
			"then": {
				"required": ["cards"],
				"properties": {
					"cards": {
						"type": "array",
						"minItems": 1,
						"items": { "$ref": "card.schema.json" }
					}
				}
			}
		},
		{
			"if": {
				"properties": { "type": { "const": "tabs_list" } },
				"required": ["type"]
			},
			"then": {
				"required": ["tabsList"]
			}
		},
		{
			"if": {
				"properties": { "type": { "const": "button_group" } },
				"required": ["type"]
			},
			"then": {
				"required": ["buttons"]
			}
		},
		{
			"if": {
				"properties": { "type": { "const": "component" } },
				"required": ["type"]
			},
			"then": {
				"required": ["component"],
				"properties": {
					"component": { "type": "string", "minLength": 1 }
				}
			}
		},
		{
			"if": {
				"properties": { "type": { "const": "data_table" } },
				"required": ["type"]
			},
			"then": {
				"anyOf": [
					{ "required": ["headers"] },
					{ "required": ["rows"] },
					{ "required": ["listData"] },
					{ "required": ["listKey"] }
				]
			}
		}
	],
	"additionalProperties": true
}
