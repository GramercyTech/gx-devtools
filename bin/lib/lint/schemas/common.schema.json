{
	"$id": "https://gxp.dev/schemas/common.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "GxP Common Definitions",
	"description": "Shared sub-schemas referenced by card and field schemas.",
	"$defs": {
		"conditionParam": {
			"type": "object",
			"description": "Conditional-display rule. Two shapes exist on the platform: {name, logic, value} and {field, operator, value}.",
			"properties": {
				"name": { "type": "string" },
				"field": { "type": "string" },
				"value": {
					"type": ["string", "number", "boolean", "array", "null"]
				},
				"logic": {
					"type": "string",
					"enum": ["==", "!=", ">", ">=", "<", "<=", "in", "not_in", "includes"]
				},
				"operator": { "type": "string" },
				"column": { "type": ["string", "null"] }
			},
			"anyOf": [
				{ "required": ["name", "logic"] },
				{ "required": ["field", "operator"] }
			],
			"additionalProperties": true
		},
		"conditionParams": {
			"type": "array",
			"items": { "$ref": "#/$defs/conditionParam" }
		},
		"gridCols": {
			"type": "integer",
			"minimum": 1,
			"maximum": 12
		},
		"colorHex": {
			"type": "string",
			"pattern": "^#(?:[0-9a-fA-F]{3}){1,2}$"
		},
		"urlOrPath": {
			"type": "string",
			"description": "Absolute URL or site-relative path",
			"pattern": "^(https?:)?(//)?/?[^\\s]*$"
		},
		"identifier": {
			"type": "string",
			"pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"
		},
		"dependencyIdentifierToken": {
			"description": "One object-scope token of a dependency: a dependency_list binding key, `*` (every object of the model in the project), `#<tag-id-or-slug>` (objects carrying the tag), `@untagged` (objects with no tags), or `@<permissionKey>` (objects related to the dependency addressed by that key — parent-scoped permissions).",
			"anyOf": [
				{ "$ref": "#/$defs/identifier" },
				{ "const": "*" },
				{ "const": "@untagged" },
				{
					"type": "string",
					"pattern": "^#[A-Za-z0-9][A-Za-z0-9_-]*$"
				},
				{
					"type": "string",
					"pattern": "^@[A-Za-z_][A-Za-z0-9_-]*$"
				}
			]
		},
		"option": {
			"type": "object",
			"description": "A selection option. The platform uses {value, text} for select/pill/multi/checkbox_group, {title, value} for autocomplete, and {option, title} for radio; {label, value} is also accepted.",
			"properties": {
				"label": { "type": "string" },
				"text": { "type": "string" },
				"title": { "type": "string" },
				"secondaryText": { "type": "string" },
				"icon": { "type": ["string", "null"] },
				"image": { "type": ["string", "null"] },
				"value": {
					"type": ["string", "number", "boolean", "null"]
				},
				"option": {
					"type": ["string", "number", "boolean", "null"],
					"description": "Radio options use `option` as the stored value key."
				},
				"disabled": { "type": "boolean" }
			},
			"anyOf": [{ "required": ["value"] }, { "required": ["option"] }],
			"additionalProperties": true
		},
		"options": {
			"type": "array",
			"items": { "$ref": "#/$defs/option" }
		}
	}
}
