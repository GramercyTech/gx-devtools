{
	"$id": "https://gxp.dev/schemas/app-manifest.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "GxP App Manifest",
	"description": "Plugin metadata + default datastore values. Read by the platform at install time and by the toolkit dev server.",
	"type": "object",
	"required": ["name", "version"],
	"properties": {
		"name": {
			"type": "string",
			"minLength": 1,
			"description": "Plugin display name."
		},
		"version": {
			"type": "string",
			"pattern": "^[0-9]+(\\.[0-9]+){0,2}([-+][A-Za-z0-9.-]+)?$",
			"description": "Semver-like plugin version."
		},
		"description": { "type": "string" },
		"manifest_version": {
			"type": "integer",
			"enum": [1, 2, 3]
		},
		"asset_dir": {
			"type": "string",
			"description": "Relative path to the asset directory, e.g. /src/public.",
			"pattern": "^/?[A-Za-z0-9._-][A-Za-z0-9/._-]*$"
		},
		"configurationFile": { "type": "string" },
		"appInstructionsFile": { "type": "string" },
		"defaultStylingFile": { "type": "string" },
		"formTemplate": {
			"type": "boolean",
			"description": "Declares this plugin as a form/quiz/survey app. When true, the platform expects `configuration.json` to include a `formTemplate` root key — an array of cards defining the starter question set an admin can customize on install."
		},
		"appInstructions": { "type": "string" },
		"defaultStyling": { "type": "string" },
		"configuration": {
			"type": ["object", "string"]
		},
		"settings": {
			"type": "object",
			"description": "Default key/value settings (pluginVars). Keys should match identifiers used in gxp-settings directives.",
			"patternProperties": {
				"^[A-Za-z_][A-Za-z0-9_]*$": {
					"type": ["string", "number", "boolean", "null", "array", "object"]
				}
			},
			"additionalProperties": false
		},
		"strings": {
			"type": "object",
			"description": "i18n strings. Must contain a `default` locale map; other keys are locale codes.",
			"properties": {
				"default": {
					"type": "object",
					"patternProperties": {
						"^[A-Za-z_][A-Za-z0-9_]*$": { "type": "string" }
					},
					"additionalProperties": false
				}
			},
			"patternProperties": {
				"^[a-z]{2}(-[A-Z]{2})?$": {
					"type": "object",
					"additionalProperties": { "type": "string" }
				}
			},
			"required": ["default"],
			"additionalProperties": true
		},
		"assets": {
			"type": "object",
			"description": "Default asset URLs/paths keyed by gxp-src identifier.",
			"patternProperties": {
				"^[A-Za-z_][A-Za-z0-9_]*$": {
					"$ref": "common.schema.json#/$defs/urlOrPath"
				}
			},
			"additionalProperties": false
		},
		"triggerState": {
			"type": "object",
			"description": "Default values for dynamic state updated by sockets/CLI.",
			"patternProperties": {
				"^[A-Za-z_][A-Za-z0-9_]*$": {
					"type": ["string", "number", "boolean", "null"]
				}
			},
			"additionalProperties": false
		},
		"dependencies": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["identifier"],
				"properties": {
					"identifier": {
						"$ref": "common.schema.json#/$defs/identifier"
					},
					"model": { "type": "string" },
					"events": { "type": "object" }
				},
				"additionalProperties": true
			}
		},
		"permissions": {
			"type": "array",
			"items": {
				"oneOf": [
					{ "$ref": "common.schema.json#/$defs/identifier" },
					{
						"type": "object",
						"required": ["identifier"],
						"properties": {
							"identifier": {
								"$ref": "common.schema.json#/$defs/identifier"
							},
							"description": { "type": "string" }
						},
						"additionalProperties": true
					}
				]
			}
		}
	},
	"additionalProperties": true
}
